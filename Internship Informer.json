        "jsCode": "// CONFIGURATION\nconst CONFIG = {\n  // Block these years if 2027 is missing\n  wrong_years: /\\b(2020|2021|2022|2023|2024|2025|2026)\\b/,\n  target_year: /2027/\n};\n\nreturn items.map(item => {\n  // 1. COMBINE TEXT\n  // We combine Title, Scraped Text, AND Original Telegram Text\n  const parts = [\n    item.json.title,\n    item.json.text,        // Cleaned HTML\n    item.json.org_text,    // Original Telegram Message (CRITICAL)\n    item.json.context\n  ];\n  \n  const combinedText = parts.filter(Boolean).join(\" \").toLowerCase();\n\n  let status = \"PASS\";\n  let rejectReason = \"N/A\";\n\n  // 2. LOGIC: Explicit Exclusion\n  // IF (Text mentions 2025/2026) AND (Text DOES NOT mention 2027) -> REJECT\n  if (CONFIG.wrong_years.test(combinedText) && !CONFIG.target_year.test(combinedText)) {\n    status = \"REJECT\";\n    rejectReason = \"Hard Filter: Explicit Old Batch (Mentioned older years but not 2027)\";\n  }\n\n  // 3. DEBUG INFO (Check this in output if it fails again)\n  const debug = {\n    original_text_found: !!item.json.org_text, // Should be TRUE\n    years_found: combinedText.match(CONFIG.wrong_years) || \"None\",\n    target_found: CONFIG.target_year.test(combinedText)\n  };\n\n  return {\n    json: {\n      ...item.json,\n      pre_filter_status: status,\n      rejection_reason: rejectReason,\n      debug_log: debug\n    }\n  };\n});"
