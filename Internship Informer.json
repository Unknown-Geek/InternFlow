    {
      "parameters": {
        "jsCode": "// 1. Get the raw content from the correct field ('text')\nlet rawContent = items[0].json.text;\n\n// 2. Safety Check: If input is missing or null\nif (!rawContent) {\n   return [{ json: { text: \"EMPTY_HTML_ERROR\" } }];\n}\n\n// 3. Handle the \"Redirect/JSON\" case (Your first screenshot)\n// If the content is a JSON string (starts with '{'), it is NOT valid HTML.\nif (typeof rawContent === 'string' && rawContent.trim().startsWith('{')) {\n   return [{ json: { text: \"EMPTY_HTML_ERROR\" } }];\n}\n\n// 4. Ensure input is a string for the Regex\nif (typeof rawContent !== 'string') {\n    // If it's somehow an object, stringify it or fail\n    try {\n        rawContent = JSON.stringify(rawContent);\n    } catch (e) {\n        return [{ json: { text: \"EMPTY_HTML_ERROR\" } }];\n    }\n}\n\n// 5. Cleaning Function\nfunction cleanText(html) {\n  if (!html) return \"\";\n  \n  // Remove <script> and <style> blocks entirely\n  let text = html.replace(/<script\\b[^>]*>([\\s\\S]*?)<\\/script>/gm, \"\");\n  text = text.replace(/<style\\b[^>]*>([\\s\\S]*?)<\\/style>/gm, \"\");\n  \n  // Remove all HTML tags\n  text = text.replace(/<[^>]+>/g, \"\\n\");\n  \n  // Collapse multiple spaces/newlines into single spaces\n  text = text.replace(/\\s+/g, \" \").trim();\n  \n  return text;\n}\n\nconst clean = cleanText(rawContent);\n\n// 6. Final Check: If the cleaned text is too short, it's likely a bad scrape.\nif (clean.length < 20) {\n    return [{ json: { text: \"EMPTY_HTML_ERROR\" } }];\n}\n\n// 7. Success Output\nreturn [{ json: { text: clean } }];"
