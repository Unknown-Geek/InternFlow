        "jsCode": "// 1. Get the current item explicitly\nconst inputItem = items[0]; \nlet rawContent = inputItem.json.html_raw;\n\n// 2. Safety Check: If input is missing or null\nif (!rawContent) {\n   return [{ json: { cleaned_text: \"EMPTY_HTML_ERROR\" } }];\n}\n\n// 3. Handle \"Redirect/JSON\" case\nif (typeof rawContent === 'string' && rawContent.trim().startsWith('{')) {\n   return [{ json: { cleaned_text: \"EMPTY_HTML_ERROR\" } }];\n}\n\n// 4. Ensure input is a string\nif (typeof rawContent !== 'string') {\n    try {\n        rawContent = JSON.stringify(rawContent);\n    } catch (e) {\n        return [{ json: { cleaned_text: \"EMPTY_HTML_ERROR\" } }];\n    }\n}\n\n// 5. HELPER: Extract Metadata (Crucial for SPAs)\nfunction getMetadata(html) {\n    let metaText = \"\";\n    \n    // Extract <title>\n    const titleMatch = html.match(/<title[^>]*>([^<]+)<\\/title>/i);\n    if (titleMatch) metaText += titleMatch[1] + \"\\n\";\n\n    // Extract <meta name=\"description\"> or <meta property=\"og:description\">\n    // We use a regex to capture the 'content' attribute\n    const descMatch = html.match(/<meta[^>]*?(?:name|property)=[\"'](?:og:)?description[\"'][^>]*?content=[\"']([^\"']+)[\"']/i);\n    if (descMatch) metaText += descMatch[1] + \"\\n\";\n\n    return metaText;\n}\n\n// 6. Cleaning Function\nfunction cleanText(html) {\n  if (!html) return \"\";\n  \n  // A. Extract metadata FIRST (Before we delete the tags)\n  const metadata = getMetadata(html);\n\n  // B. Remove scripts and styles\n  let text = html.replace(/<script\\b[^>]*>([\\s\\S]*?)<\\/script>/gm, \"\");\n  text = text.replace(/<style\\b[^>]*>([\\s\\S]*?)<\\/style>/gm, \"\");\n  \n  // C. Remove all HTML tags\n  text = text.replace(/<[^>]+>/g, \"\\n\");\n  \n  // D. Collapse spaces\n  text = text.replace(/\\s+/g, \" \").trim();\n  \n  // E. Combine Metadata + Body Text\n  // This ensures we have data even if the body was just \"Loading...\"\n  return (metadata + \"\\n\" + text).trim();\n}\n\nconst clean = cleanText(rawContent);\n\n// 7. Final Check\nif (clean.length < 20) {\n    // Return a soft error object but don't crash the flow\n    return [{ \n        json: { \n            cleaned_text: \"SCRAPE_FAILED_TOO_SHORT\", \n            error: true\n        } \n    }];\n}\n\n// 8. Success Output\nreturn [{\n  json: {\n    cleaned_text: clean,\n    // Fetch original text directly from Trigger\n    org_text: $('Telegram Trigger').first().json.message.text, \n    context: inputItem.json.context \n  }\n}];"
      },
