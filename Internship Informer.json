      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// 1. Get the raw text output safely\nconst rawText = items[0]?.json?.output;\n\nif (!rawText) {\n  return [{ json: { error: \"No output received from Analyst Agent\" } }];\n}\n\n// 2. Try to find JSON inside markdown blocks (Non-greedy is safer)\nconst markdownMatch = rawText.match(/```json\\s*([\\s\\S]*?)\\s*```/);\n\n// 3. Robust JSON Extraction (Replaces the risky Regex)\n// We simply find the first '{' and the last '}' to isolate the object.\nconst firstOpen = rawText.indexOf('{');\nconst lastClose = rawText.lastIndexOf('}');\n\nlet finalJson = {};\n\ntry {\n  if (markdownMatch) {\n    // Priority 1: Markdown block\n    finalJson = JSON.parse(markdownMatch[1]);\n  } else if (firstOpen !== -1 && lastClose !== -1 && lastClose > firstOpen) {\n    // Priority 2: Substring between first '{' and last '}'\n    const jsonString = rawText.substring(firstOpen, lastClose + 1);\n    finalJson = JSON.parse(jsonString);\n  } else {\n    // Fallback: This triggers the catch block if it's not JSON\n    throw new Error(\"No JSON structure found\");\n  }\n} catch (error) {\n  // SAFE FAILURE RESPONSE\n  finalJson = { \n    send_whatsapp: false, \n    reason: \"JSON Parsing Failed\", \n    // FIX: Added the missing comma here\n    org_text: $('HTML Cleaner').first().json.org_text || \"Text unavailable\",\n    error_details: error.message,\n    raw_output: rawText\n  };\n}\n\nreturn [{ json: finalJson }];"
      },
