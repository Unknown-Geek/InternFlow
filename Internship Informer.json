        "jsCode": "// Get the raw text output from the Agent\n// (If your agent output field is named 'text', change 'output' to 'text' below)\nconst rawText = items[0].json.output || items[0].json.text;\n\n// 1. Try to find JSON inside markdown blocks ```json ... ```\nconst markdownMatch = rawText.match(/```json\\s*([\\s\\S]*?)\\s*```/);\n\n// 2. Try to find a raw JSON object { ... }\nconst rawMatch = rawText.match(/\\{[\\s\\S]*\\}/);\n\nlet finalJson = {};\n\ntry {\n  if (markdownMatch) {\n    finalJson = JSON.parse(markdownMatch[1]);\n  } else if (rawMatch) {\n    finalJson = JSON.parse(rawMatch[0]);\n  } else {\n    // If no JSON found, return a safe failure object\n    finalJson = { \n      send_whatsapp: false, \n      reason: \"Agent failed to output valid JSON\", \n      raw_output: rawText \n    };\n  }\n} catch (error) {\n  finalJson = { \n    send_whatsapp: false, \n    reason: \"JSON Parsing Failed\", \n    error_details: error.message \n  };\n}\n\nreturn [{ json: finalJson }];"
